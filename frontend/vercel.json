{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ayush4604-popcorn-movies.hf.space/api/$1"
    },
    {
      "source": "/cdn/(.*)",
      "destination": "https://ayush4604-popcorn-movies.hf.space/cdn/$1"
    },
    {
      "source": "/vlc/(.*)",
      "destination": "https://ayush4604-popcorn-movies.hf.space/vlc/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
